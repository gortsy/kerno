# Kerno Analytics — environment variables
# ─────────────────────────────────────────
# Copy to .env then fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it's in .gitignore

# ── Required ──────────────────────────────────────────────────────────────────
# The ONLY API key the whole site needs.
# Free tier: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Recommended ───────────────────────────────────────────────────────────────
# Comma-separated list of URLs allowed to call the API.
# Add your Railway URL here after first deploy.
ALLOWED_ORIGINS=http://localhost:8000,https://your-app.railway.app

# ── Optional ──────────────────────────────────────────────────────────────────
# Gemini model — flash is free and fast, pro is more powerful
GEMINI_MODEL=models/gemini-1.5-flash

# Port — Railway sets this automatically, leave as 8000 for local dev
PORT=8000

# ── Stripe (only if you enable paid plans) ────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
